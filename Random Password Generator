<?php

function randomPasswordGenerator($length = 8) {
    $chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890!@#$%";
    $password = " ";

    for($i = 0; $i <= $length; $i++) {
        $password .= $chars[rand(0, strlen($chars) - 1)];
    }
    return $password;
}

echo "Random password: " . randomPasswordGenerator(12) . "<br>";
